# Server
PORT=8000
HOST=0.0.0.0

# LLM (MVP)
AI_MODEL=gemini-2.5-flash
GOOGLE_API_KEY=

# Session storage / retention
SESSIONS_DIR=./sessions
RETENTION_DAYS=30

# Note provider (optional)
# Leave empty for MVP (highlight only, no MCP note tools)
# Supported: notion | obsidian | file
NOTE_PROVIDER=

# Notion MCP (required when NOTE_PROVIDER=notion)
NOTION_API_KEY=

# Obsidian MCP (required when NOTE_PROVIDER=obsidian)
OBSIDIAN_VAULT_PATH=

# File system MCP (required when NOTE_PROVIDER=file)
FILE_NOTES_PATH=
